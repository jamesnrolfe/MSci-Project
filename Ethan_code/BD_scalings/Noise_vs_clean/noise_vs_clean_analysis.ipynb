    "    corrs_c = correlation_matrix(psi_c, \"Sz\", \"Sz\")[1, :]\n",
    "    corrs_n = correlation_matrix(psi_n, \"Sz\", \"Sz\")[1, :]\n",
    "    \n",
    "    # Take absolute value for Noise to see \"Glassy\" strength vs \"Néel\" oscillation\n",
    "    # Or plot raw to see the staggering\n",
